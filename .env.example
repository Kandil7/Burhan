# =============================================================================
# Athar Islamic QA System - Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
APP_NAME=Athar
APP_ENV=production              # production | development | testing
DEBUG=false                     # MUST be false in production
SECRET_KEY=CHANGE-THIS-USE-OPENSSL-RAND-HEX-32  # python -c "import secrets; print(secrets.token_hex(32))"
API_V1_PREFIX=/api/v1
WORKERS=4                       # Number of uvicorn workers

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16+)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://athar:athar_password@localhost:5432/athar_db
DATABASE_POOL_SIZE=20           # Increase for production
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30        # Connection timeout in seconds
DATABASE_POOL_RECYCLE=3600      # Recycle connections after 1 hour

# ---------------------------------------------------------------------------
# Redis (Cache & Sessions)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100
REDIS_CACHE_TTL=3600            # 1 hour default TTL

# ---------------------------------------------------------------------------
# Qdrant (Vector Database)
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                 # Set if Qdrant has auth enabled
QDRANT_COLLECTION_FIQH=fiqh_passages
QDRANT_COLLECTION_HADITH=hadith_passages
QDRANT_COLLECTION_QURAN=quran_tafsir
QDRANT_COLLECTION_GENERAL=general_islamic
QDRANT_COLLECTION_DUAS=duas_adhkar
QDRANT_COLLECTION_AQEEDAH=aqeedah_passages
QDRANT_COLLECTION_SEERAH=seerah_passages
QDRANT_COLLECTION_HISTORY=islamic_history_passages
QDRANT_COLLECTION_ARABIC=arabic_language_passages
QDRANT_COLLECTION_SPIRITUALITY=spirituality_passages
QDRANT_COLLECTION_USUL_FIQH=usul_fiqh_passages

# ---------------------------------------------------------------------------
# LLM Provider Configuration
# ---------------------------------------------------------------------------
LLM_PROVIDER=groq               # groq | openai | anthropic
GROQ_API_KEY=                   # Get from https://console.groq.com
GROQ_MODEL=qwen/qwen3-32b       # Recommended model
OPENAI_API_KEY=                 # Optional fallback
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=              # Optional
ANTHROPIC_MODEL=claude-3-sonnet-20240229
LLM_TEMPERATURE=0.1             # Low temperature for factual answers
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60                  # Request timeout in seconds
LLM_MAX_RETRIES=3               # Automatic retry count

# ---------------------------------------------------------------------------
# Embedding Model
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3     # Recommended: bge-m3 (better than qwen3)
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu            # cpu | cuda (CUDA for GPU)
EMBEDDING_BATCH_SIZE=512        # Reduce if OOM on GPU
HF_TOKEN=                       # HuggingFace token for model downloads

# ---------------------------------------------------------------------------
# Routing & Intent Classification
# ---------------------------------------------------------------------------
ROUTER_CONFIDENCE_THRESHOLD=0.75
ROUTER_FALLBACK_ENABLED=true
ROUTER_KEYWORD_WEIGHT=0.6       # Weight for keyword matching vs embedding
ROUTER_EMBEDDING_WEIGHT=0.4

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000  # Add production domains
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ---------------------------------------------------------------------------
# Logging & Monitoring
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                 # json | console (use json for production)
LOG_FILE=/var/log/athar/app.log # File path for production logging
SENTRY_DSN=                     # Optional: Sentry error tracking URL

# ---------------------------------------------------------------------------
# Rate Limiting & Security
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute   # Requests per minute per IP
RATE_LIMIT_REDIS_URL=           # Separate Redis for rate limiting (optional)
CORS_MAX_AGE=3600               # CORS preflight cache duration

# ---------------------------------------------------------------------------
# Backup & Restore (HuggingFace)
# ---------------------------------------------------------------------------
HF_BACKUP_ENABLED=false
HF_BACKUP_REPO=                 # e.g., Kandil7/Athar-Datasets
HF_BACKUP_SCHEDULE=0 2 * * *   # Daily at 2 AM (cron format)
