# Application
APP_NAME=Athar
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-in-production-please-use-random-string
API_V1_PREFIX=/api/v1

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://athar:athar_password@localhost:5432/athar_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_FIQH=fiqh_passages
QDRANT_COLLECTION_HADITH=hadith_passages
QDRANT_COLLECTION_DUA=dua_passages
QDRANT_COLLECTION_GENERAL=general_islamic

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Embeddings
EMBEDDING_MODEL=qwen3-embedding-0.5b
EMBEDDING_DIMENSION=1024

# Routing
ROUTER_CONFIDENCE_THRESHOLD=0.75
ROUTER_FALLBACK_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
