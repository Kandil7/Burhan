{
  "surahs": [
    {
      "number": 1,
      "name_ar": "الفاتحة",
      "name_en": "Al-Fatihah",
      "verse_count": 7,
      "revelation_type": "meccan",
      "ayahs": [
        {"number_in_surah": 1, "text_uthmani": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ", "juz": 1, "page": 1, "translations": [{"language": "en", "translator": "Saheeh International", "text": "In the name of Allah, the Entirely Merciful, the Especially Merciful."}]},
        {"number_in_surah": 2, "text_uthmani": "ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَـٰلَمِينَ", "juz": 1, "page": 1, "translations": [{"language": "en", "translator": "Saheeh International", "text": "All praise is due to Allah, Lord of the worlds -"}]},
        {"number_in_surah": 3, "text_uthmani": "ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ", "juz": 1, "page": 1, "translations": [{"language": "en", "translator": "Saheeh International", "text": "The Entirely Merciful, the Especially Merciful,"}]},
        {"number_in_surah": 4, "text_uthmani": "مَـٰلِكِ يَوْمِ ٱلدِّينِ", "juz": 1, "page": 1, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Sovereign of the Day of Recompense."}]},
        {"number_in_surah": 5, "text_uthmani": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ", "juz": 1, "page": 1, "translations": [{"language": "en", "translator": "Saheeh International", "text": "It is You we worship and You we ask for help."}]},
        {"number_in_surah": 6, "text_uthmani": "ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ", "juz": 1, "page": 1, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Guide us to the straight path -"}]},
        {"number_in_surah": 7, "text_uthmani": "صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّآلِّينَ", "juz": 1, "page": 1, "translations": [{"language": "en", "translator": "Saheeh International", "text": "The path of those upon whom You have bestowed favor, not of those who have evoked [Your] anger or of those who are astray."}]}
      ]
    },
    {
      "number": 112,
      "name_ar": "الإخلاص",
      "name_en": "Al-Ikhlas",
      "verse_count": 4,
      "revelation_type": "meccan",
      "ayahs": [
        {"number_in_surah": 1, "text_uthmani": "قُلْ هُوَ ٱللَّهُ أَحَدٌ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Say, \"He is Allah, [who is] One,"}]},
        {"number_in_surah": 2, "text_uthmani": "ٱللَّهُ ٱلصَّمَدُ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Allah, the Eternal Refuge."}]},
        {"number_in_surah": 3, "text_uthmani": "لَمْ يَلِدْ وَلَمْ يُولَدْ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "He neither begets nor is born,"}]},
        {"number_in_surah": 4, "text_uthmani": "وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Nor is there to Him any equivalent."}]}
      ]
    },
    {
      "number": 113,
      "name_ar": "الفلق",
      "name_en": "Al-Falaq",
      "verse_count": 5,
      "revelation_type": "meccan",
      "ayahs": [
        {"number_in_surah": 1, "text_uthmani": "قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Say, \"I seek refuge in the Lord of daybreak"}]},
        {"number_in_surah": 2, "text_uthmani": "مِن شَرِّ مَا خَلَقَ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "From the evil of that which He created"}]},
        {"number_in_surah": 3, "text_uthmani": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "And from the evil of darkness when it settles"}]},
        {"number_in_surah": 4, "text_uthmani": "وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِى ٱلْعُقَدِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "And from the evil of the blowers in knots"}]},
        {"number_in_surah": 5, "text_uthmani": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "And from the evil of an envier when he envies.\""}]}
      ]
    },
    {
      "number": 114,
      "name_ar": "الناس",
      "name_en": "An-Nas",
      "verse_count": 6,
      "revelation_type": "meccan",
      "ayahs": [
        {"number_in_surah": 1, "text_uthmani": "قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Say, \"I seek refuge in the Lord of mankind,"}]},
        {"number_in_surah": 2, "text_uthmani": "مَلِكِ ٱلنَّاسِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "The Sovereign of mankind."}]},
        {"number_in_surah": 3, "text_uthmani": "إِلَـٰهِ ٱلنَّاسِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "The God of mankind,"}]},
        {"number_in_surah": 4, "text_uthmani": "مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "From the evil of the retreating whisperer -"}]},
        {"number_in_surah": 5, "text_uthmani": "ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "Who whispers [evil] in the breasts of mankind -"}]},
        {"number_in_surah": 6, "text_uthmani": "مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ", "juz": 30, "page": 604, "translations": [{"language": "en", "translator": "Saheeh International", "text": "From among jinn and mankind.\""}]}
      ]
    }
  ]
}
