## Step 6: Embed Collections with BGE-M3

```python
from FlagEmbedding import BGEM3FlagModel
import numpy as np

# Load model
print("📦 Loading BGE-M3 model...")
model = BGEM3FlagModel('BAAI/bge-m3', use_fp16=True)
print("  ✅ Model loaded")

# Create embeddings directory
EMBEDDINGS_DIR = Path("data/embeddings")
EMBEDDINGS_DIR.mkdir(parents=True, exist_ok=True)

# Embed each collection
for collection in COLLECTIONS:
    print(f"\n🔢 Embedding {collection}...")
    
    try:
        # Load from Hugging Face
        ds = load_dataset(
            "json",
            data_files=f"hf://datasets/{REPO_ID}/collections/{collection}.jsonl.gz",
            split="train"
        )
        
        # Extract texts
        texts = [doc['content'] for doc in ds]
        print(f"  📄 {len(texts):,} documents to embed")
        
        # Embed in batches
        all_embeddings = []
        batch_size = 32
        
        for i in range(0, len(texts), batch_size):
            batch = texts[i:i+batch_size]
            result = model.encode(batch, batch_size=batch_size, max_length=8192)
            all_embeddings.append(result['dense_vecs'])
            
            if (i // batch_size) % 100 == 0:
                print(f"    Progress: {i}/{len(texts)} ({i/len(texts)*100:.1f}%)")
        
        # Save embeddings
        embeddings = np.vstack(all_embeddings)
        output_file = EMBEDDINGS_DIR / f"{collection}.npy"
        np.save(output_file, embeddings)
        
        print(f"  ✅ Embedded: {embeddings.shape}")
        print(f"  💾 Saved to: {output_file} ({output_file.stat().st_size/1e6:.1f} MB)")
        
    except Exception as e:
        print(f"  ❌ Failed: {e}")
        import traceback
        traceback.print_exc()
```

