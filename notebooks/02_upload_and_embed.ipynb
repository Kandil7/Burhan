## Step 3: Compress Collections

```python
import gzip
import json
from pathlib import Path
import time

# Local path (if running locally) or download from current location
COLLECTIONS_DIR = Path("data/processed/lucene_pages/collections")
OUTPUT_DIR = Path("data/processed/lucene_pages/upload_ready")
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

def compress_jsonl(input_path, output_path):
    """Compress JSONL to JSONL.gz"""
    start = time.time()
    line_count = 0
    
    with open(input_path, 'rb') as f_in:
        with gzip.open(output_path, 'wb', compresslevel=6) as f_out:
            import shutil
            shutil.copyfileobj(f_in, f_out)
            # Count lines
            f_in.seek(0)
            line_count = sum(1 for _ in f_in)
    
    original_size = input_path.stat().st_size
    compressed_size = output_path.stat().st_size
    ratio = compressed_size / original_size
    
    print(f"  ✓ {input_path.name}: {original_size/1e6:.1f} MB → {compressed_size/1e6:.1f} MB ({ratio:.1%})")
    print(f"    Lines: {line_count:,}, Time: {time.time()-start:.1f}s")
    
    return line_count

# Compress all collections
total_lines = 0
total_original = 0
total_compressed = 0

for collection in COLLECTIONS:
    input_file = COLLECTIONS_DIR / f"{collection}.jsonl"
    output_file = OUTPUT_DIR / f"{collection}.jsonl.gz"
    
    if input_file.exists():
        original = input_file.stat().st_size
        lines = compress_jsonl(input_file, output_file)
        compressed = output_file.stat().st_size
        
        total_lines += lines
        total_original += original
        total_compressed += compressed
    else:
        print(f"  ⚠️ {collection}.jsonl not found")

print(f"\n📊 Summary:")
print(f"  Original: {total_original/1e9:.2f} GB")
print(f"  Compressed: {total_compressed/1e9:.2f} GB")
print(f"  Savings: {(1 - total_compressed/total_original)*100:.1f}%")
print(f"  Total lines: {total_lines:,}")
```

---

## Step 4: Upload to Hugging Face

```python
from huggingface_hub import HfApi

api = HfApi()

# Upload each collection
for collection in COLLECTIONS:
    gz_file = OUTPUT_DIR / f"{collection}.jsonl.gz"
    
    if gz_file.exists():
        print(f"\n📤 Uploading {collection} ({gz_file.stat().st_size/1e6:.1f} MB)...")
        
        try:
            api.upload_file(
                path_or_fileobj=str(gz_file),
                path_in_repo=f"collections/{gz_file.name}",
                repo_id=REPO_ID,
                repo_type="dataset",
            )
            print(f"  ✅ Uploaded successfully")
        except Exception as e:
            print(f"  ❌ Failed: {e}")
    else:
        print(f"  ⚠️ {gz_file.name} not found")

print("\n✅ Upload complete!")
print(f"🔗 View at: https://huggingface.co/datasets/{REPO_ID}")
```

